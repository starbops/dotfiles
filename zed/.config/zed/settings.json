// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-9ec2174e-c04b-4b86-be6c-092c2d2f60f4",
      },
    },
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["plan"],
      },
      "type": "registry",
    },
  },
  "code_lens": "on",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_features": {
      "calt": true,
    },
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
